# Hermes Agent Environment Configuration
# Generated from server config — edit values marked with {{...}}

# =============================================================================
# HERMES HOME (directory containing this .env and config.yaml)
# =============================================================================
HERMES_HOME={{HERMES_HOME_PATH}}

# =============================================================================
# HuggingFace Mirror (for faster-whisper model download)
# =============================================================================
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_OFFLINE=0

# =============================================================================
# LLM PROVIDER (OpenCode Zen - via custom/OpenAI-compatible)
# =============================================================================
OPENAI_API_KEY={{OPENAI_API_KEY}}

# =============================================================================
# VISION (OpenRouter - for image recognition)
# =============================================================================
OPENROUTER_API_KEY={{OPENROUTER_API_KEY}}

# =============================================================================
# MESSAGING - QQ Bot via OneBot (NapCat)
# =============================================================================
ONEBOT_WS_URL=ws://127.0.0.1:3001/
ONEBOT_HTTP_URL=http://127.0.0.1:3000
ONEBOT_ACCESS_TOKEN={{ONEBOT_ACCESS_TOKEN}}

# =============================================================================
# TTS Configuration (GPT-SoVITS)
# =============================================================================
TTS_ENABLED=true
TTS_BASE_URL=http://127.0.0.1:5000/v1
TTS_MODEL=tts-1
TTS_VOICE=default

# =============================================================================
# Gateway Settings
# =============================================================================
GATEWAY_PORT=18789
GATEWAY_BIND=loopback
GATEWAY_AUTH_TOKEN={{GATEWAY_AUTH_TOKEN}}
GATEWAY_ALLOW_ALL_USERS=true

# =============================================================================
# DeepSeek API Key (for Hermes model)
# =============================================================================
DEEPSEEK_API_KEY={{DEEPSEEK_API_KEY}}

# ── QQ Official Bot v2 ──
QQ_APP_ID={{QQ_APP_ID}}
QQ_CLIENT_SECRET={{QQ_CLIENT_SECRET}}
